        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#00C853" Offset="0,5" Radius="15" Opacity="0.4" />
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="RoleCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#1E1E2E" />
        <Setter Property="Stroke" Value="#2C2C3E" />
