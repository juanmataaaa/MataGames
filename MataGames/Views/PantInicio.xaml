<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MataGames.Views.PantInicio"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1E1E2E">

    <Grid>
        <VerticalStackLayout
            Spacing="25"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <Image
                Source="dotnet_bot.png"
                HeightRequest="180"
                Aspect="AspectFit"
                HorizontalOptions="Center"/>

            <Label
                Text="MataGames"
                FontSize="40"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

            <Label
                Text="¡Bienvenido!"
                FontSize="20"
                TextColor="White"
                HorizontalTextAlignment="Center"/>

            <Label
                Text="Disfruta de nuestros juegos de mesa."
                FontSize="16"
                TextColor="LightGray"
                HorizontalTextAlignment="Center"/>

            <Button
                Text="Empezar"
                Clicked="OnEmpezarClicked"
                FontSize="20"
                WidthRequest="200"
                HeightRequest="55"
                CornerRadius="12"
                BackgroundColor="#6C63FF"
                TextColor="White"/>

        </VerticalStackLayout>
    </Grid>

</ContentPage>