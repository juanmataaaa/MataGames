<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MataGames.Views.ImpostorSetupPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Shell.BackButtonBehavior="{BackButtonBehavior IsVisible=False}"
             BackgroundColor="#0D0D14">
    <Grid>
        <Grid HorizontalOptions="Start" 
              VerticalOptions="Start" 
              Margin="20,20,0,0" 
              WidthRequest="50" 
              HeightRequest="50"
              ZIndex="1">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackClicked" />
            </Grid.GestureRecognizers>

            <Ellipse Fill="#1A1A24" Stroke="#2A2A3A" StrokeThickness="1"/>
            <Label Text="❮" TextColor="#A0A0B0" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TranslationY="-2"/>
        </Grid>

        <ScrollView Padding="20" VerticalScrollBarVisibility="Never">

            <VerticalStackLayout Spacing="0" Margin="0,60,0,0">

                <Label Text="EL IMPOSTOR" 
                       TextColor="White" 
                       FontSize="36" 
                       FontAttributes="Bold" 
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="2"
                       Margin="0,0,0,5"/>

                <Label Text="Configura tu partida secreta 🤫" 
                       TextColor="#8E8E93" 
                       FontSize="16" 
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,35"/>

                <Border Style="{StaticResource ConfigCardStyle}">
                    <VerticalStackLayout>
                        <Label Text="👥 Jugadores" Style="{StaticResource CardTitleStyle}" />

                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12" Margin="0,0,0,15">
                            <Border Grid.Column="0" BackgroundColor="#0F0F16" Stroke="#2A2A3A" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                                <Entry x:Name="txtNuevoJugador" Placeholder="Nombre del jugador..." Style="{StaticResource DarkEntryStyle}" Margin="15,0"/>
                            </Border>
                            <Button Text="+" FontSize="24" Style="{StaticResource ActionButtonStyle}" Grid.Column="1" Clicked="OnAddJugadorClicked" WidthRequest="60" Padding="0" />
                        </Grid>

                        <Border BackgroundColor="#0F0F16" Stroke="#2A2A3A" StrokeThickness="1" StrokeShape="RoundRectangle 12" HeightRequest="150">
                            <CollectionView x:Name="listaJugadores" SelectionMode="Single" SelectionChanged="OnJugadorSeleccionado" Margin="10">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="10,8">
                                            <Label Text="{Binding .}" TextColor="#E0E0E0" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                                            <BoxView HeightRequest="1" BackgroundColor="#2A2A3A" VerticalOptions="End" Margin="-10,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ConfigCardStyle}">
                    <VerticalStackLayout>

                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                            <Label Text="📝 Palabras Secretas" Style="{StaticResource CardTitleStyle}" VerticalOptions="Center" Margin="0"/>
                            <Button Text="📦 Paquetes" Grid.Column="1" BackgroundColor="#2A2A3A" TextColor="#A0A0B0" CornerRadius="8" HeightRequest="35" Padding="15,0" FontAttributes="Bold" Clicked="OnElegirPaqueteClicked"/>
                        </Grid>

                        <VerticalStackLayout x:Name="layoutManual" IsVisible="True" Spacing="15">
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                <Border Grid.Column="0" BackgroundColor="#0F0F16" Stroke="#2A2A3A" StrokeThickness="1" StrokeShape="RoundRectangle 12">
                                    <Entry x:Name="txtNuevaPalabra" Placeholder="Ej: Manzana, Coche..." Style="{StaticResource DarkEntryStyle}" Margin="15,0"/>
                                </Border>
                                <Button Text="+" FontSize="24" Style="{StaticResource ActionButtonStyle}" Grid.Column="1" Clicked="OnAddPalabraClicked" WidthRequest="60" Padding="0"/>
                            </Grid>

                            <Button x:Name="btnVerPalabras" Text="👀 Ver Lista (Mín. 10)" BackgroundColor="Transparent" BorderColor="#2A2A3A" BorderWidth="1" TextColor="#A0A0B0" CornerRadius="12" HeightRequest="50" FontAttributes="Bold" Clicked="OnVerPalabrasClicked"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="layoutAutomatico" IsVisible="False" Spacing="15">
                            <Border BackgroundColor="#0F1A14" Stroke="#00C853" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="15">
                                <Label x:Name="lblPaqueteActivo" Text="Paquete: Ninguno" TextColor="#00C853" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            </Border>
                            <Label Text="Las palabras están ocultas por seguridad." TextColor="#666677" HorizontalTextAlignment="Center" FontSize="13" FontAttributes="Italic" />
                            <Button Text="← Escribir Manualmente" BackgroundColor="Transparent" TextColor="#A0A0B0" Clicked="OnVolverManualClicked" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource ConfigCardStyle}">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="🕵️ Impostores:" Style="{StaticResource CardTitleStyle}" VerticalOptions="Center" Grid.Column="0" Margin="0"/>

                        <Border Grid.Column="1" BackgroundColor="#0F0F16" Stroke="#2A2A3A" StrokeThickness="1" StrokeShape="RoundRectangle 25" HeightRequest="50" WidthRequest="130">
                            <Grid ColumnDefinitions="40, *, 40">
                                <Button Text="-" BackgroundColor="Transparent" TextColor="#A0A0B0" FontSize="24" Grid.Column="0" Clicked="OnRestarImpostorClicked"/>
                                <Label x:Name="lblNumImpostores" Text="1" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" Grid.Column="1"/>
                                <Button Text="+" BackgroundColor="Transparent" TextColor="#6C63FF" FontSize="24" FontAttributes="Bold" Grid.Column="2" Clicked="OnSumarImpostorClicked"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Button Text="¡EMPEZAR PARTIDA!" Style="{StaticResource StartGameButtonStyle}" Clicked="OnEmpezarPartidaClicked" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>